{
	"extends": "@tsconfig/strictest/tsconfig",
	"compilerOptions": {
		"target": "ES2022",
		"strict": true,
		"declaration": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"rootDir": "src",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "dist/esm"
	},
	"include": [
		"src/**/*.ts"
	]
}
